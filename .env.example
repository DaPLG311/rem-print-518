# All external IDs are env-gated. Everything fails safe (inactive) when unset.
# Never hard-code any of these in source.

# Analytics / tracking (inactive until real accounts + consent are approved)
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_GOOGLE_ADS_ID=

# Site
NEXT_PUBLIC_SITE_URL=https://rem-print-mail.vercel.app

# Quote intake delivery — email via Resend (primary).
# The form logs safely until at least one channel is configured.
#   RESEND_API_KEY   : create at resend.com → API Keys (enables email).
#   QUOTE_TO_EMAIL   : where leads land (defaults to orders@remdigitalprint.com).
#   QUOTE_FROM_EMAIL : verified sender. Testing default is Resend's shared
#                      onboarding@resend.dev; for production, verify
#                      remdigitalprint.com in Resend and use e.g.
#                      "REM Quote Intake <quotes@remdigitalprint.com>".
RESEND_API_KEY=
QUOTE_TO_EMAIL=orders@remdigitalprint.com
QUOTE_FROM_EMAIL=

# Optional extra webhook forward (Zapier/Make/etc.) — fires alongside email.
QUOTE_WEBHOOK_URL=
